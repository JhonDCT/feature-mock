{
  "name": "feature-mock",
  "version": "1.0.0",
  "description": "CLI mock server with TUI for feature-driven development",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "bin": {
    "feature-mock": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --hot bin/cli.ts",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "mock",
    "feature",
    "tui",
    "cli",
    "bun",
    "acceptance-criteria",
    "mock-server"
  ],
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0"
  }
}
